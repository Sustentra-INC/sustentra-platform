{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustentra.local/contracts/review_decision.schema.json",
  "title": "ReviewDecision",
  "description": "A persisted human reviewer decision on one PR6 extraction candidate. Records the reviewer's action, not approved evidence (approved evidence is projected later in PR8).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_decision_id",
    "candidate_id",
    "evidence_id",
    "document_id",
    "field_name",
    "decision",
    "reviewed_value",
    "reviewed_unit",
    "reviewer_id",
    "reviewed_at",
    "reviewer_note",
    "candidate_snapshot",
    "source_reference"
  ],
  "properties": {
    "review_decision_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "field_name": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected",
        "edited",
        "needs_more_evidence"
      ]
    },
    "reviewed_value": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "reviewed_unit": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewer_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "candidate_snapshot": {
      "type": "object"
    },
    "source_reference": {
      "type": "object"
    }
  }
}
