{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustentra.local/contracts/processing_run.schema.json",
  "title": "ProcessingRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "document_id",
    "engagement_id",
    "status",
    "started_at",
    "completed_at",
    "pipeline_version",
    "error"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "engagement_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "in_progress",
        "completed",
        "failed"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "pipeline_version": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
