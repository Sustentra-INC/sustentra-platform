{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustentra.local/contracts/source_reference.schema.json",
  "title": "SourceReference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_reference_id",
    "document_id",
    "page_number",
    "sheet_name",
    "cell_or_range",
    "text_snippet",
    "bounding_box",
    "parser_block_ids"
  ],
  "properties": {
    "source_reference_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "page_number": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "sheet_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "cell_or_range": {
      "type": [
        "string",
        "null"
      ]
    },
    "text_snippet": {
      "type": [
        "string",
        "null"
      ]
    },
    "bounding_box": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      }
    },
    "parser_block_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
