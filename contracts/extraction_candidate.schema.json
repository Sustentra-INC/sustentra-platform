{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustentra.local/contracts/extraction_candidate.schema.json",
  "title": "ExtractionCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "evidence_id",
    "document_id",
    "field_name",
    "display_label",
    "raw_value",
    "normalized_value",
    "unit",
    "confidence",
    "source_reference",
    "validation_flags"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "field_name": {
      "type": "string",
      "minLength": 1
    },
    "display_label": {
      "type": "string",
      "minLength": 1
    },
    "raw_value": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "normalized_value": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "unit": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_reference": {
      "type": "object"
    },
    "validation_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
