      "label": "Flagged for auditor review",
      "meaning": "Evidence may be relevant but has ambiguity, missing critical context, conflicting identifiers, unclear role, or possible misclassification.",
      "product_action": "Open J2 gap ticket; request auditor classification or client clarification."
    },
    {
      "status": "rejected_excluded",
      "label": "Rejected / excluded",
      "meaning": "Evidence is out of scope, wrong entity/facility/period, duplicate, non-applicable, or does not support the assurance scope.",
      "product_action": "Exclude from extraction/calculation; retain documented rejection rationale."
    },
    {
      "status": "pending_clarification",
      "label": "Pending clarification",
      "meaning": "System cannot recommend accept/reject because a necessary classification fact is absent or inconsistent.",
      "product_action": "Create client/auditor clarification request; keep document inactive until resolved."
    }
