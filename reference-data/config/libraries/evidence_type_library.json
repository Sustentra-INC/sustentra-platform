      "ISO 14064",
      "NY Part 253",
      "40 CFR Part 98.37"
    ],
    "boundary_notes": [
      "This library classifies information intended to be used as evidence; it does not make final assurance conclusions.",
      "Product outputs are recommendations and structured gap triggers; final decisions remain with the auditor.",
      "OCR confidence/readability is not mandatory for J2, but source references can be stored when available.",
      "Regulatory overlays can add criteria-specific requirements without replacing the ISSA 5000 evidence framework."
    ]
  },
  "allowed_acceptance_statuses": [
    {
